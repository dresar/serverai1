# Daftar origin frontend (pisahkan koma). Wajib jika CORS_ALLOW_ALL=false.
CORS_ALLOW_ALL=false
# CORS_ORIGINS=https://your-unified-app.vercel.app

ENABLE_DEV_LOGIN=false
ENABLE_INTERNAL_TEST_ROUTES=false
EXPOSE_METRICS=true
EXPOSE_OPENAPI=true
ALLOW_CREDENTIAL_EXPORT=false
ENABLE_SELF_REGISTRATION=true

# true = migrasi saat startup (VM/Docker/lokal). Di Vercel serverless set ke false di Environment Variables.
ENABLE_RUNTIME_MIGRATIONS=true

DB_MAX_POOL=5

# --- Hanya di Vercel (Environment Variables dashboard), jangan dipakai untuk uvicorn lokal:
# VERCEL=1
# RUNTIME=serverless
# ENABLE_RUNTIME_MIGRATIONS=false
