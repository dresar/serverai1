# Salin ke .env dan isi nilai asli
DATABASE_URL=postgresql://USER:PASSWORD@HOST/DB?sslmode=require
JWT_SECRET=minimal-32-chars-secret-change-me-please
# Harus sama dengan --port uvicorn dan (jika dipakai) VITE_API_BASE_URL / proxy di ../unified
PORT=8787
NODE_ENV=development
MODE=development

CORS_ALLOW_ALL=true
# CORS_ORIGINS=https://app.example.com,https://www.example.com

ENABLE_DEV_LOGIN=true
ENABLE_RUNTIME_MIGRATIONS=true
ENABLE_INTERNAL_TEST_ROUTES=false
EXPOSE_METRICS=true
EXPOSE_OPENAPI=true
DB_MAX_POOL=10

# Seed dummy (development only): ENABLE_DEV_SEED=true python -m scripts.seed
# Reset DB + seed: ENABLE_DEV_RESET=true ENABLE_DEV_SEED=true python -m scripts.reset_and_seed
