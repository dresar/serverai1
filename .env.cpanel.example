# Salin ke .env di server cPanel Python App.
# Jalankan app sebagai Python WSGI app (Passenger) dengan startup file: passenger_wsgi.py

DATABASE_URL=postgresql://USER:PASSWORD@HOST/DB?sslmode=require
JWT_SECRET=ganti-dengan-secret-acak-min-32-char

# Wajib production
NODE_ENV=production
MODE=production

# cPanel (non-serverless)
ENABLE_RUNTIME_MIGRATIONS=true
ENABLE_INTERNAL_TEST_ROUTES=false
ENABLE_DEV_LOGIN=false

# CORS frontend production
CORS_ALLOW_ALL=false
CORS_ORIGINS=https://your-frontend-domain.com

# Opsional
EXPOSE_OPENAPI=true
EXPOSE_METRICS=true
ALLOW_CREDENTIAL_EXPORT=false
ENABLE_SELF_REGISTRATION=true
DB_MAX_POOL=5

# Jangan set VERCEL/RUNTIME=serverless di cPanel.
